# Azure Static Web Apps (Vite environment variables)
VITE_CLIENT_ID=your-azure-client-id
VITE_AUTHORITY=https://login.microsoftonline.com/common

# Azure Cosmos DB
COSMOS_DB_CONNECTION_STRING=your-cosmos-db-connection-string
COSMOS_DB_NAME=gamenight-db

# Azure Communication Services
COMMUNICATION_SERVICES_CONNECTION_STRING=your-communication-services-connection-string

# Authentication Providers
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# BoardGameGeek API (no auth needed, but might add rate limiting config)
BGG_API_BASE_URL=https://www.boardgamegeek.com/xmlapi2
